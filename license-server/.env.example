# STRIPE_BILLING_PORTAL_RETURN_URL=https://tu-sitio.com/gracias
# Enlace de acceso al portal (Stripe Dashboard → Settings → Billing → Customer portal → Login link)
# Obligatorio para licencias antiguas sin stripeCustomerId guardado
# STRIPE_PORTAL_LOGIN_URL=https://billing.stripe.com/p/login/xxxxxxxx
RESEND_API_KEY=re_xxx
EMAIL_FROM=Irishka <noreply@yourdomain.com>
APP_NAME=Irishka Group Master by SBS
ALLOW_DEMO_ENDPOINT=false
ADMIN_API_TOKEN=change_this_long_random_token
MAX_DEVICES_PER_LICENSE=1

