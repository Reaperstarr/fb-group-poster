# Microsoft Entra — misma app que registraste (ManatalCV)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Usuario cuyo OneDrive recibirá los PDF (Entra ID → Users → usuario → Object ID)
GRAPH_TARGET_USER_ID=

# Carpeta en la raíz del OneDrive (se crea sola al subir el primer archivo)
CV_UPLOAD_FOLDER=ManatalCV

# Opcional: misma clave que pongas en la extensión (cabecera X-Api-Key)
# MIRROR_API_KEY=

# Puerto local (Azure inyecta PORT automáticamente)
# PORT=8787
