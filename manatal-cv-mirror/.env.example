# --- Opción A: Azure Blob (sin Microsoft 365). Si definís esto, se ignora OneDrive/Graph.
# Storage Account → Access keys → Connection string
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# AZURE_STORAGE_CONTAINER=manatal-cv
# Días de validez del enlace de solo lectura (SAS) que devuelve /upload (por defecto 365)
# BLOB_SAS_EXPIRY_DAYS=365

# --- Opción B: OneDrive vía Graph (necesita tenant con licencia SPO/M365)
# Microsoft Entra — misma app que registraste (ManatalCV)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Usuario cuyo OneDrive recibirá los PDF (Entra ID → Users → usuario → Object ID)
GRAPH_TARGET_USER_ID=

# Carpeta (Blob: prefijo dentro del contenedor; OneDrive: carpeta en la raíz)
CV_UPLOAD_FOLDER=ManatalCV

# Opcional: misma clave que pongas en la extensión (cabecera X-Api-Key)
# MIRROR_API_KEY=

# Puerto local (Azure inyecta PORT automáticamente)
# PORT=8787
