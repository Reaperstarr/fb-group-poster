{
  "manifest_version": 3,
  "name": "Irishka Group Master by SBS",
  "version": "1.1.0",
  "description": "Postea en m\u00faltiples grupos de Facebook con texto enriquecido, im\u00e1genes y timer autom\u00e1tico.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "alarms",
    "tabs",
    "clipboardWrite",
    "clipboardRead"
  ],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://web.facebook.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Irishka Group Master by SBS"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://web.facebook.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  }
}